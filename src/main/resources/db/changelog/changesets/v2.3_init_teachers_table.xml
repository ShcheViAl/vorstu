<?xml version="1.0" encoding="UTF-8" ?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="2.3" author="vorstu">
        <createSequence sequenceName="teachers_seq" startValue="1" incrementBy="50"/>

        <createTable tableName="teachers">
            <column name="id" type="BIGINT">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="fio" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint baseTableName="teachers" baseColumnNames="user_id"
                                 constraintName="fk_teachers_users"
                                 referencedTableName="users" referencedColumnNames="id"/>

        <addColumn tableName="groups">
            <column name="teacher_id" type="BIGINT"/>
        </addColumn>

        <addForeignKeyConstraint baseTableName="groups" baseColumnNames="teacher_id"
                                 constraintName="fk_groups_teachers"
                                 referencedTableName="teachers" referencedColumnNames="id"/>

        <rollback>
            <dropForeignKeyConstraint baseTableName="groups" constraintName="fk_groups_teachers"/>
            <dropColumn tableName="groups" columnName="teacher_id"/>

            <dropForeignKeyConstraint baseTableName="teachers" constraintName="fk_teachers_users"/>
            <dropTable tableName="teachers"/>
            <dropSequence sequenceName="teachers_seq"/>
        </rollback>
    </changeSet>

</databaseChangeLog>